#!/usr/bin/env bash
# Pretty Hyprland keybind cheat sheet.
#   ‚Ä¢ run `keybinds` in any terminal
#   ‚Ä¢ or hold SUPER to show it as a floating overlay
# Single source of truth for the keybinds shown in both places.

# ‚îÄ‚îÄ Catppuccin Mocha (24-bit ANSI) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
mauve=$'\e[38;2;203;166;247m'
text=$'\e[38;2;205;214;244m'
sub=$'\e[38;2;127;132;156m'
green=$'\e[38;2;166;227;161m'
peach=$'\e[38;2;250;179;135m'
teal=$'\e[38;2;148;226;213m'
blue=$'\e[38;2;137;180;250m'
surf=$'\e[38;2;69;71;90m'
bold=$'\e[1m'; rst=$'\e[0m'

W=64
rule()    { printf "  ${surf}"; printf '‚îÄ%.0s' $(seq 1 $W); printf "${rst}\n"; }
section() { printf "\n  ${bold}%s‚ùØ %s${rst}\n" "$2" "$1"; }   # colour, title
row()     { printf "    ${mauve}%-24s${rst}${text}%s${rst}\n" "$1" "$2"; }

printf "\n  ${bold}${mauve}‚éá  Hyprland Keybinds${rst}    ${sub}hold SUPER, or type 'keybinds'${rst}\n"
rule

section "Apps & Launch" "$green"
row "SUPER + Q"               "Terminal (kitty)"
row "SUPER + Space"           "App launcher (rofi)"
row "SUPER + E"               "File manager (dolphin)"

section "Windows" "$peach"
row "SUPER + C"               "Close window"
row "SUPER + V"               "Toggle floating"
row "SUPER + M"               "Toggle fullscreen"
row "SUPER + P"               "Pseudo-tile"
row "SUPER + T"               "Toggle split direction"
row "SUPER + R"               "Resize mode: H J K L, Enter/Esc to finish"

section "Focus  (vim keys or arrows)" "$teal"
row "SUPER + H J K L"         "Move focus      left / down / up / right"
row "SUPER + SHIFT + H J K L" "Move / swap the window"

section "Workspaces" "$blue"
row "SUPER + 1-0"             "Switch to workspace 1-10"
row "SUPER + SHIFT + 1-0"     "Move window to workspace"
row "SUPER + scroll"          "Cycle through workspaces"
row "SUPER + S"               "Scratchpad (special workspace)"
row "SUPER + SHIFT + S"       "Move window to scratchpad"

section "Mouse" "$green"
row "SUPER + drag LMB"        "Move window"
row "SUPER + drag RMB"        "Resize window"

section "Media & Brightness" "$peach"
row "Volume / Media keys"     "Audio & playback control"
row "Brightness keys"         "Screen brightness"

echo
rule
printf "  ${sub}press any key, or hold SUPER again, to close${rst}\n\n"
